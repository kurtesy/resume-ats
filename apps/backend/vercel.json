{
  "buildCommand": "pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"]
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
